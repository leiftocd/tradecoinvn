{
  "version": 2,
  "builds": [
    {
      "src": "dist/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)\\.html",
      "dest": "/$1",
      "status": 301
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}